erDiagram
  CUSTOMERS ||--o{ ORDERS : places
  ORDERS ||--|{ ORDER_ITEMS : contains
  PRODUCTS ||--o{ ORDER_ITEMS : referenced_by
  PRODUCTS ||--o{ PRODUCT_CATEGORIES : mapped_to
  CATEGORIES ||--o{ PRODUCT_CATEGORIES : mapped_to
  ORDERS ||--o{ PAYMENTS : paid_by
  ORDERS ||--o| SHIPMENTS : shipped_as

  CUSTOMERS {
    int id PK
    varchar name
    varchar email
    datetime created_at
  }

  ORDERS {
    int id PK
    int customer_id FK
    datetime ordered_at
    varchar status
  }

  ORDER_ITEMS {
    int order_id FK
    int product_id FK
    int quantity
    decimal unit_price
  }

  PRODUCTS {
    int id PK
    varchar name
    varchar sku
    decimal price
  }

  CATEGORIES {
    int id PK
    varchar name
    varchar slug
  }

  PRODUCT_CATEGORIES {
    int product_id FK
    int category_id FK
    datetime assigned_at
  }

  PAYMENTS {
    int id PK
    int order_id FK
    decimal amount
    varchar method
    varchar status
    datetime paid_at
  }

  SHIPMENTS {
    int id PK
    int order_id FK
    varchar carrier
    varchar tracking_number
    datetime shipped_at
    datetime delivered_at
  }
